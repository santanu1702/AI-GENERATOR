# ════════════════════════════════════════════════════════════════
#  .env  –  Fill in your real values. NEVER commit this file!
#  Copy .env.example for reference if needed.
# ════════════════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────────────
API_ID=123456
API_HASH=your_api_hash_here
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_USERNAME=YourBotUsername
OWNER_ID=123456789

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=telegram_ai_bot

# ── AI APIs ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNWAY_API_KEY=your_runway_api_key_here

# ── Server ────────────────────────────────────────────────────
PORT=8080
