# ════════════════════════════════════════════════════════════════
#  .env.example  –  Safe template. Copy to .env and fill values.
#  This file IS safe to commit. .env is NOT.
# ════════════════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
API_ID=
API_HASH=
# Get from @BotFather on Telegram
BOT_TOKEN=
BOT_USERNAME=YourBotUsername
# Your personal Telegram user ID (get from @userinfobot)
OWNER_ID=

# ── MongoDB ───────────────────────────────────────────────────
# Get from https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=telegram_ai_bot

# ── AI APIs ───────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Get from https://platform.stability.ai/account/keys
STABILITY_API_KEY=sk-...

# Get from https://app.runwayml.com/settings
RUNWAY_API_KEY=

# ── Server ────────────────────────────────────────────────────
# Render sets this automatically; 8080 is the local default
PORT=8080

